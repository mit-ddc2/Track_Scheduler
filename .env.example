# ─────────────────────────────────────────────────────────────────────────────
# Calabogie Safety — environment variables (spec §12.5)
# Copy to `.env.local` for local dev. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_URL=

# ── App (required) ──
# APP_BASE_URL is the public origin (e.g. https://calabogie-safety.vercel.app).
# Used to build RSVP links and webhook URLs.
APP_BASE_URL=
# APP_SECRET_PEPPER seeds HMAC signatures for RSVP tokens. Generate with
# `openssl rand -base64 48`. Rotate carefully — invalidates outstanding links.
APP_SECRET_PEPPER=
# OWNER_CONTACT_PHONE is shown on the public RSVP page ("Call · <phone>"). If
# unset the page renders "Call the safety manager" without a tel: link.
OWNER_CONTACT_PHONE=

# ── Cron (required for /api/jobs/*) ──
CRON_SECRET=

# ── Messaging provider switch ──
# Set MESSAGING_PROVIDER=mock to skip Twilio and persist outgoing SMS to the
# mock_sent_sms table (viewable at /dashboard/mock-sms). Useful for dev,
# preview, and demo environments where you don't want to pay for SMS.
MESSAGING_PROVIDER=

# ── Demo reset (optional — gates POST /api/admin/reset-demo and the
#    "Reset demo data" button on /dashboard/settings).
#    Set to "true" only in environments where wiping the DB is OK. The route
#    is hard-404 unless this is exactly the string "true".
DEV_RESET_DEMO_ENABLED=

# ── Twilio (optional for v1 — SMS stubbed when MESSAGING_PROVIDER=mock or all 3 vars missing) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WEBHOOK_SECRET=

# ── Resend (optional for v1 — email stubbed when missing) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=

# ── Google Calendar OAuth (optional for v1 — calendar sync stubbed when missing) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_WEBHOOK_TOKEN=

# ── Dev-only (DO NOT set in real production) ──
# DEV_LOGIN_ENABLED=true unlocks /auth/dev-login (bypasses magic-link round-trip
# for review-mode access). When DEV_LOGIN_EMAIL is set, dev-login mints a
# session for that user. Both must be unset/false in real production.
DEV_LOGIN_ENABLED=
DEV_LOGIN_EMAIL=
